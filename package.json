{
  "name": "study-platform",
  "version": "1.0.0",
  "description": "Full-stack study platform with AI agents and coding challenges",
  "main": "api/index.js",
  "scripts": {
    "test": "echo \"Error: no test specified\" && exit 1",
    "server": "npm run dev --prefix server",
    "client": "npm run dev --prefix client",
    "dev": "npx concurrently \"npm run server\" \"npm run client\"",
    "build": "npm run build --prefix client",
    "vercel-build": "npm run build --prefix client",
    "start": "NODE_ENV=production node server/server.js",
    "seed": "node server/seeds/seedBadges.js",
    "seed:coding": "node server/seeds/seedCodingBadges.js",
    "seed:sample": "node server/seeds/seedSampleCodingQuestions.js",
    "seed:all": "npm run seed && npm run seed:coding && npm run seed:sample"
  },
  "dependencies": {
    "@google/generative-ai": "^0.24.1",
    "axios": "^1.14.0",
    "bcryptjs": "^3.0.3",
    "cloudinary": "^2.7.0",
    "compression": "^1.8.1",
    "cors": "^2.8.6",
    "crypto": "^1.0.1",
    "dotenv": "^17.3.1",
    "express": "^4.21.1",
    "express-mongo-sanitize": "^2.2.0",
    "express-rate-limit": "^8.3.1",
    "express-session": "^1.19.0",
    "express-validator": "^7.3.1",
    "helmet": "^8.1.0",
    "hpp": "^0.2.3",
    "jsonwebtoken": "^9.0.3",
    "luxon": "^3.7.2",
    "mongoose": "^9.3.0",
    "morgan": "^1.10.1",
    "multer": "^2.1.1",
    "multer-storage-cloudinary": "^4.0.0",
    "nodemailer": "^8.0.2",
    "passport": "^0.7.0",
    "passport-google-oauth20": "^2.0.0",
    "pdf-parse": "^1.1.1",
    "razorpay": "^2.9.6",
    "socket.io": "^4.8.3",
    "xss-clean": "^0.1.4"
  },
  "devDependencies": {
    "concurrently": "^8.2.2"
  },
